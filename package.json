{
  "name": "project-erve",
  "private": true,
  "version": "0.1.0",
  "description": "Distributor Inventory & Dispatch Tracking System",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @erve/api dev",
    "dev:web": "pnpm --filter @erve/web dev",
    "dev:mobile": "pnpm --filter @erve/mobile dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "prisma:generate": "pnpm --filter @erve/api prisma:generate",
    "prisma:migrate": "pnpm --filter @erve/api prisma:migrate"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
