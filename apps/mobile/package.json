{
  "name": "@erve/mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "cap:sync": "cap sync",
    "cap:add:android": "cap add android",
    "cap:run:android": "cap run android",
    "cap:run:android:live": "adb reverse tcp:4000 tcp:4000 && cap run android --live-reload --host localhost --port 5174 --forwardPorts 5174:5174"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@erve/client": "workspace:*",
    "@erve/shared": "workspace:*",
    "@erve/types": "workspace:*",
    "@erve/ui": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.7.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@erve/config": "workspace:*",
    "@erve/eslint-config": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.5.4",
    "vite": "^8.1.4"
  }
