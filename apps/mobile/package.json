{
  "name": "@erve/mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "cap:sync": "cap sync && npm run native:theme:android",
    "cap:add:android": "cap add android && npm run native:theme:android",
    "native:theme:android": "node scripts/configure-android-theme.mjs",
    "branding:generate": "node scripts/generate-branding.mjs",
    "cap:run:android": "cap run android",
    "cap:run:android:live": "adb reverse tcp:4000 tcp:4000 && cap run android --live-reload --host localhost --port 5174 --forwardPorts 5174:5174",
    "test": "vitest run"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@erve/app-components": "workspace:*",
    "@erve/client": "workspace:*",
    "@erve/layout": "workspace:*",
    "@erve/primitives": "workspace:*",
    "@erve/shared": "workspace:*",
    "@erve/theme": "workspace:*",
    "@erve/types": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.7.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@erve/config": "workspace:*",
    "@erve/eslint-config": "workspace:*",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.5.4",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
