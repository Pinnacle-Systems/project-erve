# Base URL of the API server. Local dev talks to the API directly (no
# path prefix — matches Express's own route mounting). The production
# build overrides this to the relative same-origin path "/api" instead
# (set by CI, see scripts/deployment/package-production.sh), which Nginx
# proxies to the API with the "/api" prefix stripped — see
# deployment/nginx/erve.vhost.example.conf.
VITE_API_URL=http://localhost:4000
