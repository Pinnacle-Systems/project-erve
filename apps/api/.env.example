# Server
NODE_ENV=development
PORT=4000

# PostgreSQL connection string used by Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/erve_dev?schema=public"

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="replace-with-a-random-32+-character-secret"
JWT_REFRESH_SECRET="replace-with-a-different-random-32+-character-secret"
JWT_ACCESS_EXPIRES_IN=5m
JWT_REFRESH_IDLE_TIMEOUT_MINUTES=20
JWT_REFRESH_ABSOLUTE_TIMEOUT_HOURS=8

# CORS — comma-separated exact-match allowlist (no wildcards, no prefix
# matching). http://localhost:5173 is the web Vite dev server.
# http://localhost:5174 is the mobile app's Capacitor live-reload dev flow
# (`cap:run:android:live` / `pnpm cap:run:android:live`), which serves the
# WebView content from the Vite dev server over plain HTTP instead of the
# packaged app's bundled origin.
# https://localhost is the Capacitor Android WebView origin for a packaged
# debug build (observed via WebView remote debugging / console — see
# CAPACITOR_AUTH_TESTING.md).
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://localhost
