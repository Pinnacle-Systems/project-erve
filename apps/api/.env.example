# Server
NODE_ENV=development
PORT=4000

# PostgreSQL connection string used by Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/erve_dev?schema=public"

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="replace-with-a-random-32+-character-secret"
JWT_REFRESH_SECRET="replace-with-a-different-random-32+-character-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173
